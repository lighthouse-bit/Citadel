generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============== ENUMS ==============

enum ArtworkStatus {
  DRAFT
  AVAILABLE
  SOLD
  RESERVED
  NOT_FOR_SALE
  ARCHIVED
}

enum ArtworkCategory {
  PAINTING
  DRAWING
  DIGITAL
  MIXED_MEDIA
  SCULPTURE
  PHOTOGRAPHY
}

enum CommissionStatus {
  PENDING
  REVIEWING
  ACCEPTED
  IN_PROGRESS
  REVISION
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  DEPOSIT_PAID
  FULLY_PAID
  REFUNDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ============== MODELS ==============

model Artwork {
  id           String          @id @default(uuid())
  title        String
  description  String          @db.Text
  price        Decimal         @db.Decimal(10, 2)
  category     ArtworkCategory
  medium       String?
  year         Int?
  width        Decimal?        @db.Decimal(6, 2)
  height       Decimal?        @db.Decimal(6, 2)
  depth        Decimal?        @db.Decimal(6, 2)
  unit         String          @default("inches")
  status       ArtworkStatus   @default(AVAILABLE)
  featured     Boolean         @default(false)
  displayOrder Int             @default(0)
  slug         String          @unique
  metaTitle    String?
  metaDesc     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  images        ArtworkImage[]
  tags          ArtworkTag[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]

  @@index([status])
  @@index([category])
  @@index([featured])
}

model ArtworkImage {
  id        String   @id @default(uuid())
  url       String
  publicId  String
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  artworkId String
  createdAt DateTime @default(now())

  // Relations
  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@index([artworkId])
}

model Tag {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  // Relations
  artworks ArtworkTag[]
}

model ArtworkTag {
  artworkId String
  tagId     String

  // Relations
  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([artworkId, tagId])
}

model Customer {
  id                String   @id @default(uuid())
  email             String   @unique
  firstName         String
  lastName          String
  phone             String?
  password          String?
  googleId          String?  @unique
  stripeCustomerId  String?  @unique
  isVerified        Boolean  @default(false)
  verificationToken String?  @unique
  isSuspended       Boolean  @default(false)
  suspensionReason  String?
  adminNotes        String?  @db.Text
  adminTags         String[] @default([])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  addresses     Address[]
  commissions   Commission[]
  orders        Order[]
  notifications Notification[] // ✅ Added reverse relation
  wishlistItems WishlistItem[]

  @@index([email])
}

model WishlistItem {
  id         String   @id @default(uuid())
  customerId String
  artworkId  String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  artwork  Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@unique([customerId, artworkId])
  @@index([customerId, createdAt])
  @@index([artworkId])
}

model Address {
  id         String  @id @default(uuid())
  label      String?
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  country    String
  isDefault  Boolean @default(false)
  customerId String

  // Relations
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([customerId])
}

model Order {
  id                    String        @id @default(uuid())
  orderNumber           String        @unique
  subtotal              Decimal       @db.Decimal(10, 2)
  shippingCost          Decimal       @default(0) @db.Decimal(10, 2)
  tax                   Decimal       @default(0) @db.Decimal(10, 2)
  total                 Decimal       @db.Decimal(10, 2)
  discountAmount        Decimal       @default(0) @db.Decimal(10, 2)
  promotionCode         String?
  status                OrderStatus   @default(PENDING)
  paymentStatus         PaymentStatus @default(UNPAID)
  stripePaymentIntentId String?       @unique
  shippingMethod        String?
  trackingNumber        String?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  customerNotes         String?       @db.Text
  internalNotes         String?       @db.Text
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  customerId            String
  shippingAddressId     String?
  // ✅ Add shipping tracking fields
  shippingZone          String? // "Nigeria", "Africa", "International"
  shippingSize          String? // "small", "medium", "large", "xlarge"
  carrier               String? // "DHL", "FedEx", "GIG", etc.

  trackingUrl       String? // ✅ New
  estimatedDelivery DateTime? // ✅ New

  // Relations
  customer        Customer     @relation(fields: [customerId], references: [id])
  shippingAddress Address?     @relation(fields: [shippingAddressId], references: [id])
  items           OrderItem[]
  events          OrderEvent[]

  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id        String  @id @default(uuid())
  price     Decimal @db.Decimal(10, 2)
  title     String
  orderId   String
  artworkId String

  // Relations
  artwork Artwork @relation(fields: [artworkId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Commission {
  id                     String           @id @default(uuid())
  commissionNumber       String           @unique
  artStyle               String
  size                   String
  description            String           @db.Text
  estimatedPrice         Decimal?         @db.Decimal(10, 2)
  finalPrice             Decimal?         @db.Decimal(10, 2)
  depositAmount          Decimal?         @db.Decimal(10, 2)
  balanceAmount          Decimal?         @db.Decimal(10, 2)
  depositPercentage      Int              @default(70)
  status                 CommissionStatus @default(PENDING)
  paymentStatus          PaymentStatus    @default(UNPAID)
  depositPaymentIntentId String?
  balancePaymentIntentId String?
  deadline               DateTime?
  startedAt              DateTime?
  completedAt            DateTime?
  depositPaidAt          DateTime?
  balancePaidAt          DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  customerId             String

  // Relations
  customer        Customer             @relation(fields: [customerId], references: [id])
  referenceImages CommissionImage[]
  notes           CommissionNote[]
  progressImages  CommissionProgress[]

  @@index([customerId])
  @@index([status])
}

model CommissionImage {
  id           String   @id @default(uuid())
  url          String
  publicId     String
  originalName String
  commissionId String
  createdAt    DateTime @default(now())

  // Relations
  commission Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)

  @@index([commissionId])
}

model CommissionProgress {
  id           String   @id @default(uuid())
  imageUrl     String
  publicId     String
  description  String?
  commissionId String
  createdAt    DateTime @default(now())

  // Relations
  commission Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)

  @@index([commissionId])
}

model CommissionNote {
  id           String   @id @default(uuid())
  content      String   @db.Text
  isInternal   Boolean  @default(false)
  commissionId String
  createdAt    DateTime @default(now())

  // Relations
  commission Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)

  @@index([commissionId])
}

model Admin {
  id                   String    @id @default(uuid())
  email                String    @unique
  password             String
  name                 String
  role                 String    @default("admin")
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  passwordChangedAt    DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  auditLogs   AuditLog[]
  orderEvents OrderEvent[]

  // Relations
  notifications Notification[] // ✅ Added reverse relation

  @@index([email])
}

model OrderEvent {
  id        String   @id @default(uuid())
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  orderId   String
  adminId   String?
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([adminId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([entity, entityId])
}

model Notification {
  id         String   @id @default(uuid())
  type       String // "ORDER", "COMMISSION", "SYSTEM"
  message    String
  link       String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  customerId String?
  adminId    String?

  // Relations
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  admin    Admin?    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([adminId])
  @@index([isRead])
}

model Promotion {
  id              String    @id @default(uuid())
  code            String    @unique
  name            String
  discountType    String
  value           Decimal   @db.Decimal(10, 2)
  minimumOrder    Decimal?  @db.Decimal(10, 2)
  maximumDiscount Decimal?  @db.Decimal(10, 2)
  usageLimit      Int?
  usageCount      Int       @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  isActive        Boolean   @default(true)
  categories      String[]  @default([])
  artworkIds      String[]  @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive, startsAt, endsAt])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String
  subject   String
  htmlBody  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailCampaign {
  id             String    @id @default(uuid())
  name           String
  subject        String
  htmlBody       String    @db.Text
  segment        String    @default("VERIFIED")
  status         String    @default("DRAFT")
  recipientCount Int       @default(0)
  deliveredCount Int       @default(0)
  failedCount    Int       @default(0)
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, createdAt])
}

model OperationalEvent {
  id         String    @id @default(uuid())
  type       String
  severity   String    @default("ERROR")
  message    String
  metadata   Json?
  resolved   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([resolved, severity, createdAt])
  @@index([type, createdAt])
}

model SiteSettings {
  id           String  @id @default("settings")
  siteName     String  @default("Highmarc")
  siteTagline  String? @default("Fine Art Atelier")
  artistName   String?
  artistBio    String? @db.Text
  contactEmail String?
  phone        String?
  address      String?

  // Payment
  currency  String? @default("USD")
  enableTax Boolean @default(false)
  taxRate   Float?  @default(7.5)

  // Shipping
  freeShippingThreshold Float?  @default(500)
  shippingFee           Float?  @default(0)
  internationalShipping Boolean @default(true)

  // Commissions
  commissionOpen              Boolean @default(true)
  commissionDepositPercentage Int?    @default(70)
  commissionWaitTime          String?
  minimumCommissionPrice      Float?  @default(500)

  // Social
  socialInstagram String?
  socialTwitter   String?
  socialFacebook  String?

  // SEO
  metaDescription  String? @db.Text
  heroTitle        String?
  heroSubtitle     String?
  aboutPageContent String? @db.Text

  // Policies
  shippingInfo String? @db.Text
  returnPolicy String? @db.Text

  // ✅ FIX — Add default to avoid migration error
  updatedAt DateTime @default(now()) @updatedAt
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  title     String?
  referrer  String?
  userAgent String?
  ip        String?
  country   String?
  city      String?
  device    String? // mobile, tablet, desktop
  browser   String?
  sessionId String?
  createdAt DateTime @default(now())

  // Optional — track which artwork was viewed
  artworkId String?

  @@index([path])
  @@index([createdAt])
  @@index([artworkId])
  @@index([sessionId])
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  event     String // 'view_artwork', 'add_to_cart', 'purchase', 'commission_submit'
  data      Json? // flexible metadata
  sessionId String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
}

// ── Shipping Zones ──────────────────────────────────────
model ShippingZone {
  id           String   @id @default(uuid())
  name         String // "Nigeria", "Africa", "International"
  countries    String[] // Country codes like ["NG"], ["GH", "KE"], etc.
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)

  rates ShippingRate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

// ── Shipping Rates per Zone ─────────────────────────────
model ShippingRate {
  id     String @id @default(uuid())
  zoneId String

  // Size-based pricing (USD)
  smallRate  Decimal @default(0) @db.Decimal(10, 2) // ≤ 12 inches
  mediumRate Decimal @default(0) @db.Decimal(10, 2) // 12-24 inches
  largeRate  Decimal @default(0) @db.Decimal(10, 2) // 24-36 inches
  xlargeRate Decimal @default(0) @db.Decimal(10, 2) // 36+ inches

  estimatedDays String? // "5-7 business days"
  isActive      Boolean @default(true)

  zone ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([zoneId])
  @@index([zoneId])
}
